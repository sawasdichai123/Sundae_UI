# ═══════════════════════════════════════════════════════════════════
# SUNDAE Backend — Environment Variables
#
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# SECURITY: Never commit .env to version control!
# ═══════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────
APP_NAME=SUNDAE API
DEBUG=true

# ── Supabase (Self-Hosted) ───────────────────────────────────────
# Get these values from your Supabase dashboard / docker config
SUPABASE_URL=http://your-supabase-host:8000
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_DB_URL=postgresql://postgres:postgres@your-db-host:5432/postgres

# ── Ollama / LLM ────────────────────────────────────────────────
# When running with Docker Compose, this is overridden to:
#   http://ollama:11434
# For local development without Docker, keep localhost:
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen3:14b

# ── Embedding ────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

# ── Reranker ─────────────────────────────────────────────────────
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_SCORE_THRESHOLD=0.5

# ── Chunking ─────────────────────────────────────────────────────
PARENT_CHUNK_SIZE=1500
PARENT_CHUNK_OVERLAP=200
CHILD_CHUNK_SIZE=400
CHILD_CHUNK_OVERLAP=50

# ── Vector Search ────────────────────────────────────────────────
VECTOR_SEARCH_TOP_K=20
